# ── Supabase ────────────────────────────────────────────────────────
# Settings > API dans ton dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# OTP e-mail (inscription / connexion hors @gmail.com) : Dashboard > Authentication > Providers > Email

# ── Google Gemini (agents IA + Grounding Google Search) ─────────────
# https://aistudio.google.com/app/apikey — gratuit pour commencer
# Utilisé : extraction signaux, génération rapports, grounding (fallback search)
GEMINI_API_KEY=AIza...

# ── Perplexity Search API (moteur de recherche principal des agents) ──
# https://www.perplexity.ai/settings/api
# Endpoint dédié POST /search — résultats structurés {title,url,snippet,date}
# Pas d'inférence LLM (plus rapide/moins cher que Sonar), fonctionne depuis VPS
# PRIORITÉ 1 dans la cascade : Perplexity Search → Firecrawl → DDG
PERPLEXITY_API_KEY=pplx-...

# ── Firecrawl (scraping + search — fallback Perplexity) ──────────────
# https://firecrawl.dev — 500 crédits gratuits/mois
# PRIORITÉ 2 dans la cascade de recherche
FIRECRAWL_API_KEY=fc-...

# ── Proxycurl (LinkedIn data — optionnel) ───────────────────────────
# https://nubela.co/proxycurl — ~0.01$ par profil entreprise
# À ne PAS mettre en NEXT_PUBLIC_ (clé secrète côté serveur uniquement)
PROXYCURL_API_KEY=cd80bb553705454885f5e2fd0e046ad0

# ── Cron (sécurité endpoint /api/cron/run-agents) ───────────────────
CRON_SECRET=un-secret-long-et-aleatoire

# ── App ─────────────────────────────────────────────────────────────
# En développement local
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En production (changer dans .env.production sur le VPS)
# NEXT_PUBLIC_APP_URL=https://durendal.pro

# ── SuperAdmin ──────────────────────────────────────────────────────
# L'email du compte qui aura le rôle superadmin dans Supabase
SUPERADMIN_EMAIL=ton@email.com

# ── Développement ───────────────────────────────────────────────────
# Mettre à true pour bypasser l'auth en local (ne jamais activer en prod)
AUTH_UI_BYPASS=false
