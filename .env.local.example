# ── Supabase ────────────────────────────────────────────────────────
# Settings > API dans ton dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://XXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Claude API (Anthropic) ──────────────────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Firecrawl (scraping web & presse) ──────────────────────────────
# https://firecrawl.dev — 500 scrapes/mois gratuits
FIRECRAWL_API_KEY=fc-...

# ── Proxycurl (LinkedIn data) ───────────────────────────────────────
# https://nubela.co/proxycurl — ~0.01$ par profil entreprise
# Crée un compte, va dans Dashboard > API Key
# Plans : Pay-as-you-go ou abonnement mensuel
# À ne PAS mettre en NEXT_PUBLIC_ (clé secrète côté serveur uniquement)
PROXYCURL_API_KEY=...

# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── SuperAdmin ──────────────────────────────────────────────────────
# L'email avec lequel tu t'inscris aura automatiquement le rôle SuperAdmin
SUPERADMIN_EMAIL=ton@email.com
